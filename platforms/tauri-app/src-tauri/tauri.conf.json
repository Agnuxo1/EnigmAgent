{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EnigmAgent",
  "version": "0.2.0",
  "identifier": "io.github.agnuxo1.enigmagent",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },
  "bundle": {
    "active":    true,
    "targets":   "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label":      "main",
        "title":      "EnigmAgent Vault",
        "width":      900,
        "height":     700,
        "minWidth":   640,
        "minHeight":  480,
        "resizable":  true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["$APPDATA/enigmagent/**", "$HOME/.enigmagent/**"]
    }
  }
}
