{
  "name": "enigmagent-mobile",
  "version": "0.2.0",
  "private": true,
  "description": "EnigmAgent mobile app (Android + iOS) via Capacitor",
  "type": "module",
  "scripts": {
    "setup":          "node setup.js",
    "sync":           "npx cap sync",
    "android":        "npx cap open android",
    "ios":            "npx cap open ios",
    "build:android":  "npx cap build android",
    "build:ios":      "npx cap build ios"
  },
  "dependencies": {
    "@capacitor/core":         "^6.0.0",
    "@capacitor/android":      "^6.0.0",
    "@capacitor/ios":          "^6.0.0",
    "@capacitor/splash-screen":"^6.0.0",
    "@capacitor/keyboard":     "^6.0.0",
    "@capacitor/status-bar":   "^6.0.0",
    "@capacitor/filesystem":   "^6.0.0",
    "@capacitor/preferences":  "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "author": "Francisco Angulo de Lafuente <agnuxo1@gmail.com>",
  "license": "MIT"
}
