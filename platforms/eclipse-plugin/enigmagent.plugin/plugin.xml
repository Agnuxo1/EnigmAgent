<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

  <!-- ── Template provider ───────────────────────────────────────────── -->
  <extension point="org.eclipse.ui.editors.templates">
    <contextType
        id="enigmagent.contextType"
        name="EnigmAgent Placeholders"
        class="org.eclipse.ui.texteditor.templates.TemplateContextType"/>
  </extension>

  <!-- ── Commands ────────────────────────────────────────────────────── -->
  <extension point="org.eclipse.ui.commands">
    <command
        id="enigmagent.copyPlaceholder"
        name="Copy EnigmAgent {{Placeholder}}"
        description="Copy a {{SECRET_NAME}} placeholder from the local EnigmAgent vault to clipboard"/>
    <command
        id="enigmagent.checkStatus"
        name="Check EnigmAgent Vault Status"
        description="Verify that the EnigmAgent vault REST API is reachable and unlocked"/>
  </extension>

  <!-- ── Handlers ─────────────────────────────────────────────────────── -->
  <extension point="org.eclipse.ui.handlers">
    <handler
        commandId="enigmagent.copyPlaceholder"
        class="enigmagent.plugin.CopyPlaceholderHandler"/>
    <handler
        commandId="enigmagent.checkStatus"
        class="enigmagent.plugin.VaultStatusHandler"/>
  </extension>

  <!-- ── Menu contribution ─────────────────────────────────────────────── -->
  <extension point="org.eclipse.ui.menus">
    <menuContribution locationURI="menu:edit?after=additions">
      <menu id="enigmagent.menu" label="EnigmAgent" mnemonic="E">
        <command
            commandId="enigmagent.checkStatus"
            label="Check Vault Status"
            style="push"/>
        <separator name="sep1" visible="false"/>
        <command
            commandId="enigmagent.copyPlaceholder"
            label="Copy {{Placeholder}} to Clipboard"
            style="push"/>
      </menu>
    </menuContribution>
  </extension>

  <!-- ── Preferences page ──────────────────────────────────────────────── -->
  <extension point="org.eclipse.ui.preferencePages">
    <page
        id="enigmagent.preferences"
        name="EnigmAgent Vault"
        class="enigmagent.plugin.EnigmAgentPreferencePage"
        category="org.eclipse.ui.preferencePages.GeneralTextEditor"/>
  </extension>

  <!-- ── Preference initializer ────────────────────────────────────────── -->
  <extension point="org.eclipse.core.runtime.preferences">
    <initializer class="enigmagent.plugin.PreferenceInitializer"/>
  </extension>

</plugin>
